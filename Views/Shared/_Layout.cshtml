<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Turismo Ecuador</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/turismo.styles.css" asp-append-version="true" />
</head>
<body>
    @{ 
        var isAdmin = Context.Session.GetInt32("UserId").HasValue &&
                      string.Equals(Context.Session.GetString("UserEmail"), "admin@turismo.local", StringComparison.OrdinalIgnoreCase);
        var statusMessage = TempData["StatusMessage"]?.ToString();
        var successMessage = TempData["SuccessMessage"]?.ToString();
        var errorMessage = TempData["ErrorMessage"]?.ToString();
        var authMessage = TempData["AuthMessage"]?.ToString();
        var toastMessages = new List<(string Message, string CssClass, string Title)>();

        if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            toastMessages.Add((statusMessage, "text-bg-success", "Listo"));
        }

        if (!string.IsNullOrWhiteSpace(successMessage))
        {
            toastMessages.Add((successMessage, "text-bg-success", "Éxito"));
        }

        if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            toastMessages.Add((errorMessage, "text-bg-danger", "Atención"));
        }

        if (!string.IsNullOrWhiteSpace(authMessage))
        {
            toastMessages.Add((authMessage, "text-bg-info", "Información"));
        }
    }

    @if (toastMessages.Count > 0)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 1080" aria-live="polite" aria-atomic="true">
            @for (var i = 0; i < toastMessages.Count; i++)
            {
                var toast = toastMessages[i];
                <div class="toast @toast.CssClass border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4500">
                    <div class="toast-header">
                        <strong class="me-auto">@toast.Title</strong>
                        <small>ahora</small>
                        <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Cerrar"></button>
                    </div>
                    <div class="toast-body">
                        @toast.Message
                    </div>
                </div>
            }
        </div>
    }

    <header>
        <nav class="navbar navbar-expand-lg navbar-light app-navbar border-bottom shadow-sm mb-0">
            <div class="container-fluid">
                <a class="navbar-brand app-brand" asp-area="" asp-controller="Home" asp-action="Index">Turismo Ecuador</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between" id="mainNavbar">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Inicio</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Sitios">Catálogo</a>
                        </li>
                        @if (isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Sitios" asp-action="Index">Sitios</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Ubicaciones" asp-action="Index">Ubicaciones</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Costos" asp-action="Index">Costos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Comidas" asp-action="Index">Comidas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Usuarios" asp-action="Index">Usuarios</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Auth" asp-action="Login">Ingresar</a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center gap-2 mt-3 mt-lg-0">
                        @if (isAdmin)
                        {
                            <span class="soft-badge">@Context.Session.GetString("UserName")</span>
                        }
                        else
                        {
                            <span class="text-muted small">Acceso de administrador</span>
                        }
                        @if (isAdmin)
                        {
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-secondary btn-sm">Salir</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </nav>
        @if (!isAdmin)
        {
            <div class="container pt-2">
                <div class="small text-muted d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                    <span>Explora el catálogo público o ingresa como administrador para editar la información.</span>
                    <a class="btn btn-sm btn-outline-secondary" asp-controller="Auth" asp-action="Login">Ingresar como administrador</a>
                </div>
            </div>
        }
    </header>
    <div class="container app-main">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-shell py-3 text-muted">
        <div class="container d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>&copy; 2026 - Turismo Ecuador</span>
            <span class="small">Sitios, ubicaciones, costos, comidas e imágenes</span>
            <span class="small fw-semibold">Catálogo turístico administrable</span>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var toastElements = document.querySelectorAll('.toast');
            toastElements.forEach(function (element) {
                bootstrap.Toast.getOrCreateInstance(element).show();
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
