@model Turismo.Models.CostoFormViewModel

@{
    ViewData["Title"] = "Nuevo costo";
}

<div class="page-card">
    <span class="soft-badge mb-2">Nuevo registro</span>
    <h1 class="section-title mb-3">Nuevo costo</h1>
    <p class="page-muted mb-4">Agrega valores de entrada, tarifas o cualquier costo relacionado al sitio.</p>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="mb-3">
            <label asp-for="Costo.SitioId" class="form-label">Sitio</label>
            <select asp-for="Costo.SitioId" class="form-select" asp-items="Model.Sitios"></select>
            <span asp-validation-for="Costo.SitioId" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Costo.Tipo" class="form-label">Actividad / tipo de costo</label>
            <input asp-for="Costo.Tipo" class="form-control" placeholder="Ej. Entrada general, canopy, guía local" />
            <span asp-validation-for="Costo.Tipo" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Costo.Valor" class="form-label">Valor</label>
            <input asp-for="Costo.Valor" class="form-control" />
            <span asp-validation-for="Costo.Valor" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Costo.Moneda" class="form-label">Moneda</label>
            <input asp-for="Costo.Moneda" class="form-control" placeholder="USD" />
            <span asp-validation-for="Costo.Moneda" class="text-danger"></span>
        </div>
        <div class="mb-4">
            <label asp-for="Costo.Observacion" class="form-label">Observación</label>
            <textarea asp-for="Costo.Observacion" class="form-control" rows="4"></textarea>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Guardar</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>
