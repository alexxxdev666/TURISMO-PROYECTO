@model Turismo.Domain.Entities.Sitio

@{
    ViewData["Title"] = "Detalle";
}

<div class="page-card">
    <span class="soft-badge mb-2">Detalle</span>
    <h1 class="section-title mb-3">Sitio turístico</h1>

    <dl class="row mb-4">
        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>
        <dt class="col-sm-3">Descripción</dt>
        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Sin descripción" : Model.Descripcion)</dd>
        <dt class="col-sm-3">Ubicación Id</dt>
        <dd class="col-sm-9">@Model.UbicacionId</dd>
        <dt class="col-sm-3">Estado</dt>
        <dd class="col-sm-9">@Model.Estado</dd>
        <dt class="col-sm-3">Fecha creación</dt>
        <dd class="col-sm-9">@Model.FechaCreacion.ToString("yyyy-MM-dd")</dd>
    </dl>

    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
        <a asp-action="AsociarComidas" asp-route-id="@Model.Id" class="btn btn-outline-primary">Asociar comidas</a>
        <a asp-action="UploadImages" asp-route-id="@Model.Id" class="btn btn-outline-primary">Subir imágenes</a>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>

    @{
        var imagenes = ViewBag.Imagenes as IReadOnlyList<Turismo.Domain.Entities.Multimedia>;
        var comidas = ViewBag.Comidas as IReadOnlyList<Turismo.Domain.Entities.SitioComida> ?? Array.Empty<Turismo.Domain.Entities.SitioComida>();
        var comidaNombres = ViewBag.ComidaNombres as Dictionary<int, string> ?? new Dictionary<int, string>();
        var promedioPersona = ViewBag.PromedioPersona as decimal? ?? 0m;
    }

    <hr class="my-4" />
    <h2 class="section-title mb-3">Comidas del sitio</h2>
    @if (comidas.Any())
    {
        <ul class="mb-4">
            @foreach (var comida in comidas)
            {
                var nombre = comidaNombres.TryGetValue(comida.ComidaId, out var nombreComida) ? nombreComida : $"Plato #{comida.ComidaId}";
                <li>@nombre - @(comida.ValorReferencial?.ToString("C") ?? "Sin valor")</li>
            }
        </ul>
        <div class="alert alert-info">Promedio estimado por persona: <strong>@promedioPersona.ToString("C")</strong></div>
    }
    else
    {
        <p class="page-muted mb-4">No hay comidas asociadas a este sitio.</p>
    }

    @if (imagenes != null && imagenes.Any())
    {
        <hr class="my-4" />
        <h2 class="section-title mb-3">Imágenes cargadas</h2>
        <div class="row g-3">
            @foreach (var imagen in imagenes)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="page-card h-100 p-2">
                        <img src="@imagen.Url" alt="Imagen de @Model.Nombre" class="img-fluid rounded" style="width:100%;height:220px;object-fit:cover;" />
                    </div>
                </div>
            }
        </div>
    }
</div>
