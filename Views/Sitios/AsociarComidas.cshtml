@model Turismo.Models.SitioFormViewModel

@{
    ViewData["Title"] = "Asociar comidas";
}

<div class="page-card">
    <span class="soft-badge mb-2">Relación sitio-plato</span>
    <h1 class="section-title mb-3">Asociar comidas al sitio</h1>
    <p class="page-muted mb-4">Marca los platos que pertenecen a este sitio y define un valor referencial si aplica.</p>

    <div class="mb-4 p-3 rounded-3 border bg-light-subtle">
        <div class="fw-semibold">Sitio</div>
        <div>@Model.Sitio.Nombre</div>
        <div class="text-muted small">Id: @Model.Sitio.Id</div>
        <div class="text-muted small">Platos disponibles: <span id="comidasTotales">@Model.Comidas.Count</span> | Seleccionados: <span id="comidasSeleccionadas">0</span></div>
    </div>

    <form asp-action="AsociarComidas" method="post">
        <input type="hidden" asp-for="Sitio.Id" />

        <div class="mb-3">
            <label class="form-label">Comidas asociadas al sitio</label>
            @if (Model.Comidas.Any())
            {
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <button type="button" class="btn btn-outline-primary btn-sm" id="seleccionarTodasBtn">Seleccionar todas</button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" id="quitarTodasBtn">Quitar todas</button>
                </div>
                <div class="border rounded-3 p-3 bg-light-subtle">
                    <div class="row g-3">
                        @for (var i = 0; i < Model.Comidas.Count; i++)
                        {
                            <div class="col-12 col-lg-6">
                                <div class="p-3 rounded-3 border bg-white h-100">
                                    <div class="form-check mb-2">
                                        <input type="hidden" asp-for="Comidas[i].ComidaId" />
                                        <input class="form-check-input comida-selector" asp-for="Comidas[i].Seleccionada" />
                                        <label class="form-check-label fw-semibold" asp-for="Comidas[i].Seleccionada">@Model.Comidas[i].Nombre</label>
                                    </div>
                                    <div class="row g-2 align-items-end">
                                        <div class="col-12 col-md-6">
                                            <label class="form-label mb-1">Valor por persona</label>
                                            <input asp-for="Comidas[i].ValorReferencial" class="form-control" type="number" step="0.01" min="0" placeholder="Ej. 3" />
                                            <span asp-validation-for="Comidas[i].ValorReferencial" class="text-danger small"></span>
                                        </div>
                                        <div class="col-12 col-md-6">
                                            <label class="form-label mb-1">Observación</label>
                                            <input asp-for="Comidas[i].Observacion" class="form-control" placeholder="Opcional" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="form-text">Solo se guardarán los platos marcados.</div>
            }
            else
            {
                <div class="alert alert-warning mb-3">No hay comidas registradas todavía. Crea al menos una comida para poder asociarla.</div>
                <a asp-controller="Comidas" asp-action="Create" class="btn btn-primary">Crear comida</a>
            }
        </div>

        <div class="d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary">Guardar asociaciones</button>
            <a asp-action="Details" asp-route-id="@Model.Sitio.Id" class="btn btn-secondary">Volver</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        (() => {
            const checks = Array.from(document.querySelectorAll('.comida-selector'));
            const totalLabel = document.getElementById('comidasTotales');
            const selectedLabel = document.getElementById('comidasSeleccionadas');
            const selectAllButton = document.getElementById('seleccionarTodasBtn');
            const clearAllButton = document.getElementById('quitarTodasBtn');

            const refreshCount = () => {
                const selectedCount = checks.filter(check => check.checked).length;
                if (selectedLabel) {
                    selectedLabel.textContent = String(selectedCount);
                }
                if (totalLabel) {
                    totalLabel.textContent = String(checks.length);
                }
            };

            checks.forEach(check => check.addEventListener('change', refreshCount));

            if (selectAllButton) {
                selectAllButton.addEventListener('click', () => {
                    checks.forEach(check => check.checked = true);
                    refreshCount();
                });
            }

            if (clearAllButton) {
                clearAllButton.addEventListener('click', () => {
                    checks.forEach(check => check.checked = false);
                    refreshCount();
                });
            }

            refreshCount();
        })();
    </script>
}
