@{
    ViewData["Title"] = "Inicio";
    var isAdmin = Context.Session.GetInt32("UserId").HasValue &&
                  string.Equals(Context.Session.GetString("UserEmail"), "admin@turismo.local", StringComparison.OrdinalIgnoreCase);
}

<section class="page-hero mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <span class="soft-badge mb-3">Sistema turístico administrado</span>
            <h1 class="display-5 fw-bold">Administra tu catálogo turístico de forma simple y clara</h1>
            <p class="lead muted-on-hero mb-2">Consulta sitios, registra ubicaciones, administra costos y organiza el contenido con una interfaz más limpia y amigable.</p>
            <p class="muted-on-hero mb-4">El acceso a los catálogos y operaciones CRUD está restringido exclusivamente al usuario Administrador.</p>
            <div class="d-flex flex-wrap gap-2">
                @if (isAdmin)
                {
                    <a class="btn btn-light btn-lg" asp-controller="Sitios" asp-action="Index">Ver sitios</a>
                    <a class="btn btn-outline-light btn-lg" asp-controller="Ubicaciones" asp-action="Index">Ver ubicaciones</a>
                }
                else
                {
                    <a class="btn btn-light btn-lg" asp-controller="Auth" asp-action="Login">Ingresar como administrador</a>
                }
            </div>
        </div>
        <div class="col-lg-5">
            <div class="bg-white text-dark rounded-4 p-4 shadow-sm">
                <h2 class="h5 fw-bold">Acceso rápido</h2>
                <p class="page-muted mb-4">@((isAdmin) ? "Todo lo que necesitas está a un clic." : "Inicia sesión para ver los catálogos administrativos.")</p>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="feature-card">
                            <div class="feature-icon">📍</div>
                            <div class="fw-semibold">Ubicaciones</div>
                            <div class="small page-muted">Provincias, cantones y parroquias.</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="feature-card">
                            <div class="feature-icon">🏞️</div>
                            <div class="fw-semibold">Sitios</div>
                            <div class="small page-muted">Catálogo turístico principal.</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="feature-card">
                            <div class="feature-icon">💲</div>
                            <div class="fw-semibold">Costos</div>
                            <div class="small page-muted">Valores y observaciones.</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="feature-card">
                            <div class="feature-icon">🔐</div>
                            <div class="fw-semibold">Usuarios</div>
                            <div class="small page-muted">Acceso y administración.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="row g-3">
    @if (isAdmin)
    {
        <div class="col-md-4">
            <div class="page-card h-100">
                <h3 class="h5 fw-bold">Sitios</h3>
                <p class="page-muted">Gestiona los lugares turísticos con datos claros y navegación directa.</p>
                <a class="btn btn-primary" asp-controller="Sitios" asp-action="Index">Abrir</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="page-card h-100">
                <h3 class="h5 fw-bold">Ubicaciones</h3>
                <p class="page-muted">Organiza la estructura territorial y mantén relaciones jerárquicas fáciles de entender.</p>
                <a class="btn btn-primary" asp-controller="Ubicaciones" asp-action="Index">Abrir</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="page-card h-100">
                <h3 class="h5 fw-bold">Usuarios</h3>
                <p class="page-muted">Administra el acceso al sistema desde un único panel.</p>
                <a class="btn btn-primary" asp-controller="Usuarios" asp-action="Index">Abrir</a>
            </div>
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="page-card">
                <h3 class="h5 fw-bold">Acceso restringido</h3>
                <p class="page-muted">Los catálogos y operaciones CRUD solo están disponibles para el usuario Administrador autenticado.</p>
                <a class="btn btn-primary" asp-controller="Auth" asp-action="Login">Ir al login</a>
            </div>
        </div>
    }
</div>
