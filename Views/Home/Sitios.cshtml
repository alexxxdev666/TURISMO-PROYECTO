@model IReadOnlyList<Turismo.Domain.Entities.Sitio>

@{
    ViewData["Title"] = "Catalogo de Sitios Turisticos";
    var portadas = ViewBag.Portadas as Dictionary<int, string> ?? new Dictionary<int, string>();
    var ubicaciones = ViewBag.Ubicaciones as Dictionary<int, Turismo.Domain.Entities.Ubicacion?> ?? new Dictionary<int, Turismo.Domain.Entities.Ubicacion?>();
    var ubicacionesCompletas = ViewBag.UbicacionesCompletas as Dictionary<int, string> ?? new Dictionary<int, string>();
    var rutas = ViewBag.Rutas as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="page-card mb-4">
    <div class="mb-4">
        <h1 class="section-title mb-2">Catalogo de Sitios Turisticos</h1>
        <p class="page-muted mb-0">Descubre destinos con imagenes, ubicacion jerarquica, actividades y referencias utiles para planificar la visita.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="table-card">
        <div class="empty-state">No hay sitios disponibles en este momento.</div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var sitio in Model)
        {
            var portada = portadas.TryGetValue(sitio.Id, out var urlPortada) ? urlPortada : null;
            var ubicacion = ubicaciones.TryGetValue(sitio.Id, out var ubicacionCatalogo) ? ubicacionCatalogo : null;
            var ubicacionCompleta = ubicacionesCompletas.TryGetValue(sitio.Id, out var ubicacionRuta) ? ubicacionRuta : null;
            var ruta = rutas.TryGetValue(sitio.Id, out var rutaCatalogo) ? rutaCatalogo : null;
            var actividades = (sitio.Actividades ?? string.Empty)
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Take(3)
                .ToArray();

            <div class="col-md-6 col-lg-4">
                <div class="page-card site-card h-100 d-flex flex-column position-relative">
                    @if (!string.IsNullOrWhiteSpace(portada))
                    {
                        <img src="@portada" alt="Portada de @sitio.Nombre" class="site-card-image" />
                    }
                    else
                    {
                        <div class="site-card-placeholder">Sin imagen</div>
                    }

                    <div class="site-card-body d-flex flex-column h-100">
                        <span class="soft-badge mb-2">@sitio.Estado</span>
                        <h5 class="fw-bold mb-2">@sitio.Nombre</h5>

                        @if (ubicacion != null)
                        {
                            <div class="text-muted small mb-2">
                                <strong>@ubicacion.Tipo:</strong> @ubicacion.Nombre
                            </div>
                        }

                        @if (!string.IsNullOrWhiteSpace(ubicacionCompleta))
                        {
                            <div class="text-muted small site-card-location mb-3">@ubicacionCompleta</div>
                        }

                        @if (actividades.Length > 0)
                        {
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var actividad in actividades)
                                {
                                    <span class="soft-badge activity-badge">@actividad</span>
                                }
                            </div>
                        }

                        <p class="text-muted mb-3 site-card-description">
                            @(string.IsNullOrWhiteSpace(sitio.Descripcion) ? "Sin descripcion disponible." : sitio.Descripcion)
                        </p>

                        <div class="d-flex flex-wrap gap-2 mt-auto">
                            <a asp-action="SitioDetalle" asp-route-id="@sitio.Id" class="btn btn-sm btn-primary flex-grow-1">
                                Ver detalle
                            </a>
                            @if (!string.IsNullOrWhiteSpace(ruta))
                            {
                                <a href="@ruta" class="btn btn-sm btn-outline-primary" target="_blank" rel="noopener noreferrer">Como llegar</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
.site-card {
    overflow: hidden;
    padding: 0;
    background: #fffdf8;
}

.site-card-image {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
}

.site-card-placeholder {
    height: 220px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #dff3eb 0%, #fff4dc 100%);
    color: #0a5f50;
    font-weight: 600;
}

.site-card-body {
    padding: 1.5rem;
}

.site-card-location {
    min-height: 3rem;
    line-height: 1.4;
}

.site-card-description {
    font-size: 0.95rem;
    flex-grow: 1;
}

.activity-badge {
    background: #fff1d6;
    color: #8a4d12;
    font-size: 0.78rem;
}
</style>
