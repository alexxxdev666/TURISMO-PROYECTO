@model Turismo.Domain.Entities.Sitio

@{
    ViewData["Title"] = Model.Nombre;

    var ubicacion = ViewBag.Ubicacion as Turismo.Domain.Entities.Ubicacion;
    var ubicacionCompleta = ViewBag.UbicacionCompleta as string;
    var latitud = ubicacion?.Latitud;
    var longitud = ubicacion?.Longitud;
    var tieneCoordenadas = latitud.HasValue && longitud.HasValue;
    var latitudTexto = latitud?.ToString("0.000000") ?? string.Empty;
    var longitudTexto = longitud?.ToString("0.000000") ?? string.Empty;
    var latitudRuta = latitud?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
    var longitudRuta = longitud?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;

    var costos = ViewBag.Costos as IReadOnlyList<Turismo.Domain.Entities.Costo> ?? Array.Empty<Turismo.Domain.Entities.Costo>();
    var comidas = ViewBag.Comidas as IReadOnlyList<Turismo.Domain.Entities.SitioComida> ?? Array.Empty<Turismo.Domain.Entities.SitioComida>();
    var comidaNombres = ViewBag.ComidaNombres as Dictionary<int, string> ?? new Dictionary<int, string>();
    var portadasComidas = ViewBag.PortadasComidas as Dictionary<int, string?> ?? new Dictionary<int, string?>();
    var imagenes = ViewBag.Imagenes as IReadOnlyList<Turismo.Domain.Entities.Multimedia> ?? Array.Empty<Turismo.Domain.Entities.Multimedia>();

    var promedioPersona = ViewBag.PromedioPersona is decimal promedioPersonaValue ? promedioPersonaValue : 0m;
    var promedioCostos = ViewBag.PromedioCostos is decimal promedioCostosValue ? promedioCostosValue : 0m;
    var promedioComidas = ViewBag.PromedioComidas is decimal promedioComidasValue ? promedioComidasValue : 0m;
    var cantidadCostosPromediados = ViewBag.CantidadCostosPromediados is int cantidadCostosValue ? cantidadCostosValue : 0;
    var cantidadComidasPromediadas = ViewBag.CantidadComidasPromediadas is int cantidadComidasValue ? cantidadComidasValue : 0;

    var actividades = (Model.Actividades ?? string.Empty)
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var actividadImagenes = imagenes.Any() ? imagenes.ToArray() : Array.Empty<Turismo.Domain.Entities.Multimedia>();

    var usd = new System.Globalization.CultureInfo("en-US");
    var fechaCuraduria = "10/06/2026";
}

<div class="mb-4">
    <a href="@Url.Action("Sitios", "Home")" class="btn btn-outline-primary btn-sm mb-3">
        Volver al catalogo
    </a>
</div>

<div class="page-card detail-hero mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-4">
        <div class="flex-grow-1">
            <div class="d-flex flex-wrap gap-2 mb-3">
                <span class="soft-badge">@Model.Estado</span>
                <span class="soft-badge soft-badge-light">Actualizado @fechaCuraduria</span>
            </div>

            <h1 class="section-title mb-3">@Model.Nombre</h1>

            @if (!string.IsNullOrWhiteSpace(Model.Descripcion))
            {
                <p class="page-muted mb-4">@Model.Descripcion</p>
            }

            @if (actividades.Length > 0)
            {
                <div class="mb-3">
                    <h6 class="eyebrow mb-2">Actividades recomendadas</h6>
                    <div class="activity-card-grid">
                        @for (var i = 0; i < actividades.Length; i++)
                        {
                            var actividad = actividades[i];
                            var imagenActividad = actividadImagenes.Length > 0 ? actividadImagenes[i % actividadImagenes.Length].Url : null;

                            <div class="activity-card">
                                @if (!string.IsNullOrWhiteSpace(imagenActividad))
                                {
                                    <img src="@imagenActividad" alt="Actividad @actividad en @Model.Nombre" class="activity-image" />
                                }
                                else
                                {
                                    <div class="activity-image activity-image-placeholder"></div>
                                }
                                <div class="activity-overlay">
                                    <span class="activity-label">@actividad</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

    </div>
</div>

<div class="page-card mb-4">
    <div class="row g-4">
        <div class="col-lg-8">
            <h5 class="fw-bold mb-3">Ubicacion del destino</h5>

            @if (ubicacion != null)
            {
                <div class="detail-list">
                    <div class="detail-item">
                        <span class="detail-label">Punto exacto</span>
                        <span class="detail-value">@ubicacion.Tipo: @ubicacion.Nombre</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(ubicacionCompleta))
                    {
                        <div class="detail-item">
                            <span class="detail-label">Ruta geografica</span>
                            <span class="detail-value">@ubicacionCompleta</span>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(ubicacion.Descripcion))
                    {
                        <div class="detail-item">
                            <span class="detail-label">Referencia</span>
                            <span class="detail-value">@ubicacion.Descripcion</span>
                        </div>
                    }

                    @if (tieneCoordenadas)
                    {
                        <div class="detail-item">
                            <span class="detail-label">Coordenadas</span>
                            <span class="detail-value">@latitudTexto, @longitudTexto</span>
                        </div>
                    }
                </div>

                <div class="d-flex flex-wrap gap-2 mt-3">
                    @if (tieneCoordenadas)
                    {
                        <a class="btn btn-primary btn-sm" href="https://www.google.com/maps/dir/?api=1&destination=@latitudRuta,@longitudRuta" target="_blank" rel="noopener noreferrer">Como llegar</a>
                        <a class="btn btn-outline-secondary btn-sm" href="#mapaSitio">Ver mapa</a>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">Este sitio aun no tiene una ubicacion detallada registrada.</div>
            }
        </div>

        <div class="col-lg-4">
            <div class="price-callout">
                <span class="eyebrow">Promedio estimado por persona</span>
                <div class="price-value">@promedioPersona.ToString("C", usd)</div>
                <p class="text-muted small mb-2">Promedio entre costos del sitio y platos asociados con precio disponible.</p>
                <p class="text-muted small mb-0">
                    Costos (@cantidadCostosPromediados): <strong>@promedioCostos.ToString("C", usd)</strong><br />
                    Comidas (@cantidadComidasPromediadas): <strong>@promedioComidas.ToString("C", usd)</strong>
                </p>
            </div>
        </div>
    </div>
</div>

<div class="page-card mb-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">Galeria del sitio</h5>
            <p class="text-muted mb-0">Imagenes curadas para este destino.</p>
        </div>
        <span class="soft-badge soft-badge-light">@imagenes.Count imagenes</span>
    </div>

    @if (imagenes.Any())
    {
        <div class="row g-3">
            @foreach (var imagen in imagenes)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="gallery-card h-100">
                        <img src="@imagen.Url" alt="Imagen de @Model.Nombre" class="gallery-image" />
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">Este sitio aun no tiene imagenes publicadas.</div>
    }
</div>

<div class="page-card mb-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">Gastronomia asociada</h5>
            <p class="text-muted mb-0">Valores referenciales consultados en linea el @fechaCuraduria.</p>
        </div>
        <span class="soft-badge soft-badge-light">@comidas.Count platos registrados</span>
    </div>

    @if (comidas.Any())
    {
        <div class="row g-3">
            @foreach (var comida in comidas)
            {
                var nombre = comidaNombres.TryGetValue(comida.ComidaId, out var nombreComida)
                    ? nombreComida
                    : $"Plato #{comida.ComidaId}";
                var portada = portadasComidas.TryGetValue(comida.ComidaId, out var urlPortadaComida)
                    ? urlPortadaComida
                    : null;
                var precio = comida.ValorReferencial.HasValue
                    ? comida.ValorReferencial.Value.ToString("C", usd)
                    : "Sin precio";

                <div class="col-12 col-md-6 col-xl-4">
                    <div class="food-card h-100">
                        @if (!string.IsNullOrWhiteSpace(portada))
                        {
                            <img src="@portada" alt="Imagen de @nombre" class="food-image" />
                        }
                        else
                        {
                            <div class="food-placeholder">Sin imagen</div>
                        }

                        <div class="food-body">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <div class="fw-semibold">@nombre</div>
                                <span class="soft-badge">@precio</span>
                            </div>
                            <div class="text-muted small">Valor referencial por porcion o consumo individual.</div>

                            @if (!string.IsNullOrWhiteSpace(comida.Observacion))
                            {
                                <div class="food-note mt-3">@comida.Observacion</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">No hay platos registrados para este sitio.</div>
    }
</div>

<div class="page-card mb-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">Costos y tarifas</h5>
            <p class="text-muted mb-0">Referencias de entrada y actividades consultadas el @fechaCuraduria.</p>
        </div>
        <span class="soft-badge soft-badge-light">@costos.Count registros</span>
    </div>

    @if (costos.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-friendly mb-0">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Valor</th>
                        <th>Moneda</th>
                        <th>Observacion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var costo in costos)
                    {
                        <tr>
                            <td class="fw-semibold">@costo.Tipo</td>
                            <td>@(costo.Valor <= 0 ? "Gratis" : costo.Valor.ToString("C", usd))</td>
                            <td><span class="soft-badge soft-badge-light">@costo.Moneda</span></td>
                            <td>@(string.IsNullOrWhiteSpace(costo.Observacion) ? "Sin observacion" : costo.Observacion)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">No hay costos registrados para este sitio.</div>
    }
</div>

<div class="page-card mb-4" id="mapaSitio">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
        <div>
            <h5 class="fw-bold mb-1">Mapa interactivo</h5>
            <p class="text-muted mb-0">Ubicacion referencial del destino basada en coordenadas registradas.</p>
        </div>

        @if (tieneCoordenadas)
        {
            <span class="soft-badge soft-badge-light">Leaflet + OpenStreetMap</span>
        }
    </div>

    @if (tieneCoordenadas)
    {
        <div id="publicSiteMap" class="route-map" data-lat="@latitudRuta" data-lon="@longitudRuta"></div>
    }
    else
    {
        <div class="empty-state">Este sitio todavia no tiene coordenadas registradas para mostrar el mapa.</div>
    }
</div>

<div class="page-card">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
        <div>
            <h5 class="fw-bold mb-1">Ficha curada</h5>
            <p class="text-muted mb-0">Contenido enriquecido con imagenes, ubicacion jerarquica y precios referenciales.</p>
        </div>
        <div class="text-muted small">Fecha de creacion del registro: @Model.FechaCreacion.ToString("dd/MM/yyyy")</div>
    </div>
</div>

<style>
.detail-hero {
    background: linear-gradient(135deg, rgba(255, 253, 248, 0.98) 0%, rgba(224, 243, 235, 0.98) 100%);
}

.soft-badge-light {
    background: #fff1d6;
    color: #8a4d12;
}

.eyebrow {
    display: inline-block;
    color: #64748b;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.activity-badge {
    background: #dff3eb;
    color: #0a5f50;
}

.detail-list {
    display: grid;
    gap: 0.9rem;
}

.detail-item {
    display: grid;
    gap: 0.2rem;
}

.detail-label {
    color: #64748b;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
}

.detail-value {
    color: #0f172a;
    line-height: 1.5;
}

.price-callout {
    height: 100%;
    border-radius: 0.9rem;
    padding: 1.25rem;
    background: linear-gradient(135deg, #e4f4ed 0%, #fffaf0 100%);
    border: 1px solid rgba(15, 139, 111, 0.16);
}

.price-value {
    font-size: 2rem;
    font-weight: 700;
    color: #0a5f50;
    margin: 0.35rem 0 0.5rem;
}

.gallery-card,
.food-card {
    overflow: hidden;
    border-radius: 0.9rem;
    border: 1px solid rgba(15, 139, 111, 0.14);
    background: #fffdf8;
    box-shadow: 0 12px 26px rgba(51, 61, 45, 0.08);
}

.gallery-image {
    width: 100%;
    height: 250px;
    object-fit: cover;
    display: block;
}

.food-image {
    width: 100%;
    height: 190px;
    object-fit: cover;
    display: block;
}

.food-placeholder {
    height: 190px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #dff3eb 0%, #fff4dc 100%);
    color: #0a5f50;
    font-weight: 600;
}

.food-body {
    padding: 1rem;
}

.food-note {
    color: #64748b;
    font-size: 0.88rem;
    line-height: 1.45;
}
</style>

@if (tieneCoordenadas)
{
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9dT/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var mapElement = document.getElementById('publicSiteMap');
            if (!mapElement) {
                return;
            }

            var latitud = parseFloat(mapElement.dataset.lat);
            var longitud = parseFloat(mapElement.dataset.lon);
            if (Number.isNaN(latitud) || Number.isNaN(longitud)) {
                return;
            }

            var map = L.map('publicSiteMap', { scrollWheelZoom: false }).setView([latitud, longitud], 14);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                maxZoom: 19,
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            L.marker([latitud, longitud]).addTo(map)
                .bindPopup('@Model.Nombre')
                .openPopup();
        });
    </script>
}
