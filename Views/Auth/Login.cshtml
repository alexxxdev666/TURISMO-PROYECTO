@model Turismo.Models.LoginViewModel

@{
    ViewData["Title"] = "Ingresar";
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
    var accessMessage = ViewData["AccessMessage"]?.ToString();
    var authMessage = ViewData["AuthMessage"]?.ToString();
}

<div class="row justify-content-center align-items-center">
    <div class="col-lg-5 col-md-7">
        <div class="login-card">
            <span class="soft-badge mb-3">Bienvenido</span>
            <h1 class="h3 fw-bold mb-2">Ingresa al sistema</h1>
            <p class="page-muted mb-4">Accede para administrar el contenido turístico con seguridad y rapidez.</p>
            @if (!string.IsNullOrWhiteSpace(authMessage))
            {
                <div class="alert alert-success rounded-4 mb-4">@authMessage</div>
            }
            @if (!string.IsNullOrWhiteSpace(accessMessage))
            {
                <div class="alert alert-warning rounded-4 mb-4">@accessMessage</div>
            }
            <div class="alert alert-info rounded-4 mb-4">
                Usuario inicial: <strong>admin@turismo.local</strong><br />
                Clave: <strong>Admin2628</strong>
            </div>

            <form asp-action="Login" method="post">
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label asp-for="Email" class="form-label">Correo electrónico</label>
                    <input asp-for="Email" class="form-control form-control-lg" placeholder="tu@correo.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Password" class="form-label">Contraseña</label>
                    <input asp-for="Password" class="form-control form-control-lg" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary btn-lg w-100">Entrar</button>
            </form>

            <div class="mt-4 small page-muted">
                Si intentaste abrir una sección protegida, después del login volverás automáticamente a esa página.
            </div>
        </div>
    </div>
</div>
