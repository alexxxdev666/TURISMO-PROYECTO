@model IReadOnlyList<Turismo.Domain.Entities.Comida>

@{
    ViewData["Title"] = "Comidas";

    var sitiosPorComida = ViewBag.SitiosPorComida as Dictionary<int, List<string>> ?? new Dictionary<int, List<string>>();
    var portadasComidas = ViewBag.PortadasComidas as Dictionary<int, string?> ?? new Dictionary<int, string?>();
}

<div class="page-card mb-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <span class="soft-badge mb-2">Gastronomia vinculada</span>
        <h1 class="section-title mb-2">Comidas por sitio turistico</h1>
        <p class="page-muted mb-0">Revisa cada plato junto al destino donde aparece, para que el administrador no se vea vacio ni desconectado.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Nueva comida</a>
</div>

@if (!Model.Any())
{
    <div class="empty-state">Todavia no hay comidas registradas.</div>
}
else
{
    <div class="row g-3">
        @foreach (var comida in Model)
        {
            var portada = portadasComidas.TryGetValue(comida.Id, out var portadaEncontrada) ? portadaEncontrada : null;
            var sitios = sitiosPorComida.TryGetValue(comida.Id, out var sitiosEncontrados) ? sitiosEncontrados : new List<string>();

            <div class="col-12 col-lg-6">
                <div class="admin-food-card h-100">
                    @if (!string.IsNullOrWhiteSpace(portada))
                    {
                        <img src="@portada" alt="Imagen de @comida.Nombre" class="admin-food-image" />
                    }
                    else
                    {
                        <div class="admin-food-placeholder">
                            <span>@comida.Nombre.Substring(0, 1).ToUpperInvariant()</span>
                        </div>
                    }

                    <div class="admin-food-body">
                        <div class="d-flex flex-column flex-md-row justify-content-between gap-2">
                            <div>
                                <span class="soft-badge soft-badge-light mb-2">Plato tradicional</span>
                                <h5 class="fw-bold mb-1">@comida.Nombre</h5>
                                <p class="text-muted small mb-0">Sitios turisticos donde esta comida aparece asociada.</p>
                            </div>
                            <div class="text-md-end text-nowrap">
                                <a asp-action="Edit" asp-route-id="@comida.Id">Editar</a> |
                                <a asp-action="UploadImages" asp-route-id="@comida.Id">Imagenes</a> |
                                <a asp-action="Delete" asp-route-id="@comida.Id">Eliminar</a>
                            </div>
                        </div>

                        <div class="mt-3">
                            @if (sitios.Count > 0)
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    @foreach (var sitio in sitios)
                                    {
                                        <span class="soft-badge">@sitio</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-state py-3">Sin sitio turistico asociado todavia.</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
