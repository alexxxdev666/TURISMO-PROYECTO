@model Turismo.Domain.Entities.Ubicacion

@{
    ViewData["Title"] = "Detalle de ubicación";
    var ubicacionPadre = ViewBag.UbicacionPadre as Turismo.Domain.Entities.Ubicacion;
    var ubicacionCompleta = ViewBag.UbicacionCompleta as string ?? Model.Nombre;
    var tieneCoordenadas = Model.Latitud.HasValue && Model.Longitud.HasValue;
    var latitud = Model.Latitud ?? -0.1807;
    var longitud = Model.Longitud ?? -78.4678;
}

<div class="page-card mb-4">
    <span class="soft-badge mb-2">Detalle</span>
    <h1 class="section-title mb-3">Ubicación</h1>

    <dl class="row mb-4">
        <dt class="col-sm-3">Nombre</dt>
        <dd class="col-sm-9">@Model.Nombre</dd>
        <dt class="col-sm-3">Tipo</dt>
        <dd class="col-sm-9"><span class="soft-badge">@Model.Tipo</span></dd>
        <dt class="col-sm-3">Padre</dt>
        <dd class="col-sm-9">@(ubicacionPadre == null ? "-" : $"{ubicacionPadre.Tipo}: {ubicacionPadre.Nombre}")</dd>
        <dt class="col-sm-3">Descripción</dt>
        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Descripcion) ? "Sin descripción" : Model.Descripcion)</dd>
        <dt class="col-sm-3">Ruta completa</dt>
        <dd class="col-sm-9">@ubicacionCompleta</dd>
        <dt class="col-sm-3">Coordenadas</dt>
        <dd class="col-sm-9">@(tieneCoordenadas ? $"{latitud:F6}, {longitud:F6}" : "Sin coordenadas")</dd>
    </dl>

    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
        <a asp-action="Index" class="btn btn-secondary">Volver</a>
    </div>
</div>

<div class="page-card mb-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
        <div>
            <h2 class="section-title mb-1">Mapa interactivo</h2>
            <p class="page-muted mb-0">Desde Quito hasta la ubicación seleccionada.</p>
        </div>
        <span class="soft-badge">Leaflet + OpenStreetMap</span>
    </div>

    @if (tieneCoordenadas)
    {
        <div id="routeMap" class="route-map" data-lat="@latitud" data-lon="@longitud"></div>
        <div class="mt-3 small text-muted" id="routeStatus">Cargando mapa...</div>
    }
    else
    {
        <div class="empty-state mb-0">
            Esta ubicación no tiene coordenadas aún. Edita la ubicación y selecciónalas en el mapa para activar la ruta desde Quito.
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script>
        document.addEventListener('DOMContentLoaded', async function () {
            const mapContainer = document.getElementById('routeMap');
            const statusElement = document.getElementById('routeStatus');
            if (!mapContainer || !statusElement) {
                return;
            }

            const destinationLat = parseFloat(mapContainer.dataset.lat);
            const destinationLon = parseFloat(mapContainer.dataset.lon);

            try {
                const quito = await geocode('Quito, Pichincha, Ecuador');
                const map = L.map('routeMap');

                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    maxZoom: 18,
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(map);

                const quitoMarker = L.marker([quito.lat, quito.lon]).addTo(map).bindPopup('Quito');
                const destinationMarker = L.marker([destinationLat, destinationLon], { draggable: true }).addTo(map).bindPopup('Destino');
                let routeLayer = L.geoJSON(await fetchRoute(quito, { lat: destinationLat, lon: destinationLon }), {
                    style: { color: '#2563eb', weight: 5, opacity: 0.9 }
                }).addTo(map);

                map.fitBounds(routeLayer.getBounds(), { padding: [30, 30] });
                destinationMarker.openPopup();
                statusElement.textContent = 'Puedes mover el marcador del destino para ver otra ruta.';

                destinationMarker.on('dragend', async function (event) {
                    const position = event.target.getLatLng();
                    try {
                        map.removeLayer(routeLayer);
                        routeLayer = L.geoJSON(await fetchRoute(quito, { lat: position.lat, lon: position.lng }), {
                            style: { color: '#2563eb', weight: 5, opacity: 0.9 }
                        }).addTo(map);
                        map.fitBounds(routeLayer.getBounds(), { padding: [30, 30] });
                        statusElement.textContent = `Ruta actualizada hacia ${position.lat.toFixed(6)}, ${position.lng.toFixed(6)}.`;
                    } catch {
                        statusElement.textContent = 'No se pudo actualizar la ruta.';
                    }
                });

                quitoMarker.bindPopup('Quito');
            } catch {
                mapContainer.innerHTML = '<div class="empty-state mb-0">No fue posible cargar la ruta del mapa en este momento.</div>';
                statusElement.textContent = 'No se pudo resolver la ruta automáticamente.';
            }

            async function geocode(query) {
                const response = await fetch(`https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&q=${encodeURIComponent(query)}`, {
                    headers: { 'Accept': 'application/json' }
                });

                if (!response.ok) {
                    throw new Error('Geocoding failed');
                }

                const results = await response.json();
                if (!results.length) {
                    throw new Error('No results');
                }

                return {
                    lat: parseFloat(results[0].lat),
                    lon: parseFloat(results[0].lon)
                };
            }

            async function fetchRoute(origin, destination) {
                const url = `https://router.project-osrm.org/route/v1/driving/${origin.lon},${origin.lat};${destination.lon},${destination.lat}?overview=full&geometries=geojson`;
                const response = await fetch(url);

                if (!response.ok) {
                    throw new Error('Routing failed');
                }

                const data = await response.json();
                if (!data.routes || !data.routes.length) {
                    throw new Error('No route');
                }

                return data.routes[0].geometry;
            }
        });
    </script>
}
