@model Turismo.Domain.Entities.Ubicacion

@{
    ViewData["Title"] = "Eliminar ubicación";
}

<div class="page-card">
    <span class="soft-badge mb-2" style="background:#fee2e2;color:#991b1b;">Acción irreversible</span>
    <h1 class="section-title mb-2">Eliminar ubicación</h1>
    <p class="page-muted mb-4">¿Deseas eliminar <strong>@Model.Nombre</strong>? Esta acción no se puede deshacer.</p>

    <form asp-action="Delete" method="post" class="d-flex gap-2">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
