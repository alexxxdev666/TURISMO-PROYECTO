@model IReadOnlyList<Turismo.Domain.Entities.Ubicacion>

@{
    ViewData["Title"] = "Ubicaciones";
    var parentNombres = ViewBag.ParentNombres as Dictionary<int, string> ?? new Dictionary<int, string>();
}

<div class="page-card mb-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
        <span class="soft-badge mb-2">Estructura territorial</span>
        <h1 class="section-title mb-2">Ubicaciones</h1>
        <p class="page-muted mb-0">Organiza provincias, cantones y parroquias de manera sencilla.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Nueva ubicación</a>
</div>

<div class="table-card">
    @if (!Model.Any())
    {
        <div class="empty-state">No hay ubicaciones registradas todavía.</div>
    }
    else
    {
        <table class="table table-striped table-friendly mb-0">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Tipo</th>
                    <th>Padre</th>
                    <th>Descripción</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var ubicacion in Model)
            {
                <tr>
                    <td class="fw-semibold">@ubicacion.Nombre</td>
                    <td><span class="soft-badge">@ubicacion.Tipo</span></td>
                    <td>@(ubicacion.ParentId.HasValue && parentNombres.TryGetValue(ubicacion.ParentId.Value, out var parentNombre) ? parentNombre : "-")</td>
                    <td>@(string.IsNullOrWhiteSpace(ubicacion.Descripcion) ? "-" : ubicacion.Descripcion)</td>
                    <td class="text-nowrap">
                        <a asp-action="Details" asp-route-id="@ubicacion.Id">Detalle</a> |
                        <a asp-action="Edit" asp-route-id="@ubicacion.Id">Editar</a> |
                        <a asp-action="Delete" asp-route-id="@ubicacion.Id">Eliminar</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
